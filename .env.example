# ============================================
# Astribot Daily Agent - 环境变量配置
# ============================================
# 复制此文件为 .env 并填入真实值

# --- 飞书配置 ---
FEISHU_APP_ID=cli_xxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxx
FEISHU_BITABLE_APP_TOKEN=bascnxxxxxxxxxx        # 多维表格 App Token
FEISHU_BITABLE_TABLE_ID=tblxxxxxxxxxx            # 数据表 ID
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/xxxxxxxx  # 群机器人 Webhook

# --- 飞书文档归档配置（二选一或两者都配）---
FEISHU_DOC_ID=doxcnxxxxxxxxxx                    # 追加模式：日报归档文档 ID（所有日报追加到同一文档）
FEISHU_DOC_FOLDER_TOKEN=fldcnxxxxxxxxxx          # 新建模式：每天创建新文档到此文件夹

# --- GitLab 配置 ---
GITLAB_URL=https://gitlab.astribot.com
GITLAB_PRIVATE_TOKEN=glpat-xxxxxxxxxxxxxxxxxx
GITLAB_USE_MOCK=false                            # 生产建议 false；开发演示可改为 true

# --- LLM 配置 ---
# 📌 推荐使用 LLM_ 前缀；也兼容 OPENAI_ 前缀（已有环境变量无需改名）
#
# 方式一：直接配置（适用所有 OpenAI 兼容接口）
LLM_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxx
LLM_BASE_URL=https://api.openai.com/v1        # 可切换为其他兼容端点
LLM_MODEL=gpt-4o                              # 模型名称
#
# 方式二：使用 provider 快捷预设（自动设置 base_url 和 model）
# LLM_PROVIDER=deepseek                       # 只需填 provider + api_key，其余自动配置
# LLM_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxx
#
# 可选：省 token 参数
# LLM_MAX_TOKENS=2048                         # 输出上限（默认 4096，日报通常 1500 左右即可）
# LLM_TEMPERATURE=0.3                         # 生成温度（默认 0.3）
#
# ─── 国产模型快捷接入示例 ───
# DeepSeek（推荐，性价比最高）:
#   LLM_PROVIDER=deepseek
#   LLM_API_KEY=sk-xxx
#
# 智谱 GLM-4（免费额度大）:
#   LLM_PROVIDER=zhipu
#   LLM_API_KEY=xxx.xxx
#
# 通义千问:
#   LLM_PROVIDER=qwen
#   LLM_API_KEY=sk-xxx
#
# Moonshot (Kimi):
#   LLM_PROVIDER=moonshot
#   LLM_API_KEY=sk-xxx
#
# 本地 Ollama（完全免费、离线运行）:
#   LLM_PROVIDER=ollama
#   LLM_API_KEY=ollama
#
# ─── 向后兼容 ───
# 如果已有 OPENAI_API_KEY 等环境变量，无需修改，Agent 会自动识别：
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxx
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o

# --- Agent 配置 ---
REPORT_HOURS_LOOKBACK=24                         # 回溯小时数
SCHEDULE_CRON=0 9 * * 1-5                        # 每周一到周五早上9点
LOG_LEVEL=INFO
